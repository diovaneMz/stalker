<UserControl x:Class="Stalker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Stalker.ViewModels"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <TextBlock Text="STALKER" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>

                <!-- Active game indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding HasActiveGame, Converter={StaticResource BoolToVis}}">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource ActiveGreenBrush}" Margin="0,0,6,0"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource ActiveGreenBrush}">
                        <Run Text="Jogando agora: "/>
                        <Run Text="{Binding ActiveGameName, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <Button Style="{StaticResource AccentButton}"
                        Content="+ Adicionar Jogo"
                        Command="{Binding AddGameCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="13"/>
            </Grid>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="1" Margin="20,16,20,8">
            <Border Style="{StaticResource InputBorder}" Height="38">
                <TextBox Style="{StaticResource SearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </Border>
            <TextBlock Text="&#xE721; Buscar jogos..."
                       FontFamily="Segoe MDL2 Assets, Segoe UI"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="13"
                       IsHitTestVisible="False"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Game List -->
        <ScrollViewer Grid.Row="2" Margin="20,0,20,16">
            <ItemsControl ItemsSource="{Binding FilteredGames}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource GameCard}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.OpenGameDetailCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter"/>
                            </Border.Triggers>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Cover placeholder -->
                                <Border Grid.Column="0" Width="40" Height="40"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="6">
                                    <TextBlock Text="{Binding Name[0]}"
                                               FontSize="18" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Name + last played -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{StaticResource ActiveGreenBrush}"
                                                 Margin="8,0,0,0" VerticalAlignment="Center"
                                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0">
                                        <Run Text="Último: "/>
                                        <Run Text="{Binding LastPlayedFormatted, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Total time -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0"
                                            HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TotalPlayTimeFormatted}"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="tempo total" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </StackPanel>

                                <!-- Arrow -->
                                <TextBlock Grid.Column="3" Text="&#xE76C;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
