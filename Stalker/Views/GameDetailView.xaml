<UserControl x:Class="Stalker.Views.GameDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Stalker.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer>
        <StackPanel Margin="20">

            <!-- Back button -->
            <Button Style="{StaticResource GhostButton}"
                    Command="{Binding GoBackCommand}"
                    HorizontalAlignment="Left"
                    Padding="8,6"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Voltar" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="56" Height="56" Background="{StaticResource AccentBrush}" CornerRadius="10">
                    <TextBlock Text="{Binding GameName[0]}" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding GameName}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0">
                        <Run Text="Primeira vez: "/>
                        <Run Text="{Binding FirstPlayedAt, Mode=OneWay, FallbackValue='—'}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Milestone buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding MarkCompletedCommand}"
                            Padding="10,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2713;" FontSize="14" Margin="0,0,4,0"
                                       Foreground="{Binding IsCompleted, Converter={StaticResource BoolToAccentBrush}}"/>
                            <TextBlock Text="Zerado" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}"
                            Command="{Binding MarkPlatinumCommand}"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2605;" FontSize="14" Margin="0,0,4,0"
                                       Foreground="{Binding IsPlatinum, Converter={StaticResource BoolToGoldBrush}}"/>
                            <TextBlock Text="100%" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats Row -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource GameCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Tempo total" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalPlayTime}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource GameCard}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="Última sessão" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding LastPlayed}" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource GameCard}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Zerado em" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CompletedAt, FallbackValue='—'}" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Weekly Chart -->
            <Border Style="{StaticResource GameCard}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Horas por semana" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <lvc:CartesianChart Series="{Binding WeeklySeries}"
                                        XAxes="{Binding XAxes}"
                                        Height="180"
                                        Background="Transparent"/>
                </StackPanel>
            </Border>

            <!-- Session History -->
            <TextBlock Text="Sessões recentes" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

            <ItemsControl ItemsSource="{Binding Sessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="8" Padding="16,12" Margin="0,0,0,6">
                            <Grid>
                                <TextBlock Text="{Binding Date}" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Duration}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
