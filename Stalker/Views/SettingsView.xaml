<UserControl x:Class="Stalker.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Stalker.ViewModels"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <ScrollViewer>
        <StackPanel Margin="20">

            <TextBlock Text="Configurações" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- Account Section -->
            <TextBlock Text="CONTA" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

            <Border Style="{StaticResource GameCard}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="40" Height="40" CornerRadius="20"
                            Background="{StaticResource AccentBrush}">
                        <TextBlock Text="{Binding UserDisplayName[0]}" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding UserDisplayName}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Conta conectada" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                            Command="{Binding LogoutCommand}"
                            Content="Sair" VerticalAlignment="Center"
                            Foreground="#EF4444"/>
                </Grid>
            </Border>

            <!-- App Section -->
            <TextBlock Text="APLICATIVO" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

            <Border Style="{StaticResource GameCard}" Margin="0,0,0,8">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Iniciar com o Windows" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Abre automaticamente ao ligar o computador" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox IsChecked="{Binding StartWithWindows}" HorizontalAlignment="Right"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Style="{StaticResource GameCard}">
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Minimizar para bandeja" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Ao fechar, mantém rodando em segundo plano" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox IsChecked="{Binding MinimizeToTray}" HorizontalAlignment="Right"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
